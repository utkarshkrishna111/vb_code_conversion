# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Set only the key for the provider you chose above
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Model overrides (optional — sensible defaults are set per provider)
# AGENT_MODEL=claude-sonnet-4-6     # spoke agents
# HUB_MODEL=claude-opus-4-7         # hub agent

# ── Pipeline ──────────────────────────────────────────────────────────────────
MAX_RETRIES=3
COMPLEXITY_THRESHOLD=0.7

# ── Qdrant (optional — uses in-memory if not set) ─────────────────────────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── GitHub (optional — PR creation skipped if not set) ────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=owner/repo-name
